# =========================
# Configuración de la API HS4
# =========================

HS4_API_BASE_URL=http://quamtum.hs4
HS4_USERNAME=admin
HS4_PASSWORD=your_password_here

# =========================
# Base de datos y aplicación
# =========================

DATABASE_PATH=lte_telemetry.db

# Tiempo entre consultas (segundos)
POLL_INTERVAL=8

# Tiempo de aprendizaje para detección base (minutos)
LEARN_MINUTES=10

# Puerto del servidor GPS local
GPS_PORT=8766

# Puerto web reservado
WEB_PORT=8765

# Nivel de logs
LOG_LEVEL=INFO

# Nombre del mapa HTML generado
MAP_OUTPUT_HTML=lte_telemetry_map.html
